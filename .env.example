BLENDER_MCP_SERVER_NAME=blender-mcp
BLENDER_MCP_SERVER_VERSION=0.1.0
BLENDER_MCP_TRANSPORT=stdio
BLENDER_MCP_ENABLE_UNAUTHENTICATED_HTTP=false
BLENDER_MCP_HTTP_HOST=127.0.0.1
BLENDER_MCP_HTTP_PORT=8765
BLENDER_MCP_HTTP_ALLOWED_ORIGINS=http://localhost
BLENDER_MCP_HTTP_AUTH_TOKEN=
BLENDER_MCP_HTTP_AUTH_ROLE=editor
BLENDER_MCP_HTTP_MAX_REQUEST_BYTES=1048576
BLENDER_MCP_REPO_ROOT=
BLENDER_MCP_WORKSPACE_ROOTS=./workspace
BLENDER_MCP_CONTROLLER_MODE=mock
BLENDER_MCP_CONTROLLER_HOST=127.0.0.1
BLENDER_MCP_CONTROLLER_PORT=8766
BLENDER_MCP_CONTROLLER_SECRET=
BLENDER_MCP_CONTROLLER_ATTACH_TIMEOUT_SECONDS=0
BLENDER_MCP_CONTROLLER_START_TIMEOUT_SECONDS=20
BLENDER_MCP_CONTROLLER_HEARTBEAT_SECONDS=5
BLENDER_MCP_SAFE_MODE_DEFAULT=true
BLENDER_MCP_DEFAULT_ROLE=editor
BLENDER_MCP_DESTRUCTIVE_SNAPSHOT_THRESHOLD=3
BLENDER_MCP_MAX_SAFE_MODE_POLYGON_BUDGET=100000
BLENDER_MCP_METRICS_LATENCY_WINDOW=256
BLENDER_MCP_BLENDER_BINARY=
BLENDER_MCP_LOG_LEVEL=INFO
