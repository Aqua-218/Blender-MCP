{
  "$id": "https://blender-mcp.local/schemas/common-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "created_object_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "deleted_object_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "errors": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "file_paths": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "image_paths": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "modified_object_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "next_suggestions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "request_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "partial_success",
        "failed"
      ],
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "status",
    "request_id",
    "tool_name",
    "summary"
  ],
  "title": "CommonToolResult",
  "type": "object"
}
